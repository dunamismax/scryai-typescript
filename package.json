{
  "name": "scry-home",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint": "bunx @biomejs/biome check . && UV_CACHE_DIR=${UV_CACHE_DIR:-/tmp/uv-cache-scry-home} uv run ruff check .",
    "lint:biome": "bunx @biomejs/biome check .",
    "lint:ruff": "UV_CACHE_DIR=${UV_CACHE_DIR:-/tmp/uv-cache-scry-home} uv run ruff check .",
    "format": "bunx @biomejs/biome format --write . && UV_CACHE_DIR=${UV_CACHE_DIR:-/tmp/uv-cache-scry-home} uv run ruff format .",
    "scry:bootstrap": "uv run python -m scripts bootstrap",
    "scry:doctor": "uv run python -m scripts doctor",
    "scry:setup:workstation": "uv run python -m scripts setup:workstation",
    "scry:setup:config_backup": "uv run python -m scripts setup:config_backup",
    "scry:verify:config_backup": "uv run python -m scripts verify:config_backup",
    "scry:setup:ssh_backup": "uv run python -m scripts setup:ssh_backup",
    "scry:setup:ssh_restore": "uv run python -m scripts setup:ssh_restore",
    "scry:projects:list": "uv run python -m scripts projects:list",
    "scry:projects:doctor": "uv run python -m scripts projects:doctor",
    "scry:projects:install": "uv run python -m scripts projects:install",
    "scry:projects:verify": "uv run python -m scripts projects:verify",
    "scry:sync:openclaw": "uv run python -m scripts sync:openclaw",
    "scry:specialists:harden": "uv run python -m scripts specialists:harden",
    "scry:cron:reconcile": "uv run python -m scripts cron:reconcile",
    "scry:sync:remotes": "uv run python -m scripts sync:remotes",
    "scry:sync:work-desktop": "uv run python -m scripts sync:work-desktop"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5"
  }
}
