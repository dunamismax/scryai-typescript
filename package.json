{
  "name": "grimoire",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "bunx @biomejs/biome check . && uv run ruff check .",
    "lint:biome": "bunx @biomejs/biome check .",
    "lint:ruff": "uv run ruff check .",
    "format": "bunx @biomejs/biome format --write . && uv run ruff format .",
    "scry:bootstrap": "python3 -m scripts bootstrap",
    "scry:doctor": "python3 -m scripts doctor",
    "scry:setup:workstation": "python3 -m scripts setup:workstation",
    "scry:setup:config_backup": "python3 -m scripts setup:config_backup",
    "scry:verify:config_backup": "python3 -m scripts verify:config_backup",
    "scry:setup:ssh_backup": "python3 -m scripts setup:ssh_backup",
    "scry:setup:ssh_restore": "python3 -m scripts setup:ssh_restore",
    "scry:projects:list": "python3 -m scripts projects:list",
    "scry:projects:doctor": "python3 -m scripts projects:doctor",
    "scry:projects:install": "python3 -m scripts projects:install",
    "scry:projects:verify": "python3 -m scripts projects:verify",
    "scry:sync:openclaw": "python3 -m scripts sync:openclaw",
    "scry:specialists:harden": "python3 -m scripts specialists:harden",
    "scry:cron:reconcile": "python3 -m scripts cron:reconcile",
    "scry:sync:remotes": "python3 -m scripts sync:remotes",
    "scry:sync:work-desktop": "python3 -m scripts sync:work-desktop"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^24.3.0",
    "bun-types": "^1.3.9",
    "typescript": "^5.9.2"
  }
}
